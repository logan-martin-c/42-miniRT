{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make-debug",
            "type": "shell",
            "command": "make",
            "args": [
                "debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Runs 'make debug' to compile the program with debugging symbols."
        }
    ]
}