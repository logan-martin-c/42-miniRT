{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: Run with Args (make debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/miniRT_debug",
            //"program": "${workspaceFolder}/checker_debug",
            //"args": [""],
            "args": ["maps/sphere.rt"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // This is the crucial line: it runs the task defined in tasks.json before starting the debugger.
            "preLaunchTask": "make-debug"
        }
    ]
}
